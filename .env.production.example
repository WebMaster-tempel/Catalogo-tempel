NODE_ENV=production
PORT=3000

# MySQL — fill with values from cPanel "MySQL Databases"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tempelgroup_catalog
DB_USER=tempelgroup_catuser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API security key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=CHANGE_ME_GENERATE_RANDOM_HEX

API_KEY_HEADER=X-API-Key

# Public URL of this subdomain (no trailing slash)
BASE_URL=https://catalogo.tempelgroup.com
